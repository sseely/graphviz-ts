# IDE
.idea/
.vscode/

# Dependencies
node_modules/

# npm pack output (local consumable package tarball)
*.tgz

# Build output
dist/
build/

# TypeScript
*.tsbuildinfo

# Parser generator output is committed (see AD-11), so only ignore
# intermediate build artifacts here
*.js.map

# Test
coverage/
test/golden/actual/

# Serena MCP project state — broadened from .serena/cache/ to the whole dir;
# stray copies get created when a tool runs with a subdirectory as its cwd.
.serena/

# Per-directory MCP server config auto-generated by serena/claude tooling
.mcp.json

# Claude session artifacts
.claude/worktrees/
.claude/settings.local.json
.claude/settings.autonomous.json
# Local autonomous-mode settings + the toggle's backup of the prior settings
.claude/settings.json
.claude/settings.pre-autonomous.json

# Scratch DOT repros generated during debugging (e.g. 2371_k1000.dot)
/2371_k*.dot

# Local debug/probe scratch scripts
.probes/

# VitePress docs-site build cache (dist/ is already ignored above)
docs-site/.vitepress/cache/

# Generated report mirrors copied into the site at build (docs:copy-reports);
# the source of truth is test/corpus/PARITY.md and test/corpus/PERF.md.
docs-site/parity.md
docs-site/perf.md

# Corpus survey transient log + any in-repo oracle SVG cache (AD-3: cache is
# gitignored; default cache lives under the OS tmpdir, outside the repo)
survey.log
test/corpus/oracle-cache/
