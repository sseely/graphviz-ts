{
  "name": "graphviz-ts",
  "version": "0.1.0",
  "type": "module",
  "license": "EPL-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "default": "./dist/render.js"
    }
  },
  "scripts": {
    "build": "npm run build:js && npm run build:types",
    "build:js": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=dist/index.js && esbuild src/api/index.ts --bundle --format=esm --sourcemap --outfile=dist/api.js && esbuild src/render/index.ts --bundle --format=esm --sourcemap --outfile=dist/render.js",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@xmldom/xmldom": "^0.9.10",
    "canvas": "^3.2.3",
    "esbuild": "^0.28.1",
    "peggy": "^4.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.0",
    "vitest": "^4.1.9"
  },
  "volta": {
    "node": "26.3.1"
  }
}
