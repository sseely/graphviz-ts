{
  "name": "graphviz-ts",
  "version": "0.1.0",
  "type": "module",
  "license": "EPL-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js",
    "./render": "./dist/render.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js && esbuild src/api/index.ts --bundle --format=esm --outfile=dist/api.js && esbuild src/render/index.ts --bundle --format=esm --outfile=dist/render.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@xmldom/xmldom": "^0.9.10",
    "canvas": "^3.2.3",
    "esbuild": "^0.28.1",
    "peggy": "^4.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.0",
    "vitest": "^4.1.9"
  },
  "volta": {
    "node": "26.3.1"
  }
}
