{
  "fallbackModel": "opus",
  "permissions": {
    "allow": [
      "Bash(npm *:*)",
      "Bash(npx *:*)",
      "Bash(node *:*)",
      "Bash(git *:*)",
      "Bash(python3 *:*)",
      "Bash(make *:*)",
      "Bash(cc *:*)",
      "Bash(clang *:*)",
      "Bash(otool *:*)",
      "Bash(~/git/graphviz/build/cmd/dot/dot:*)",
      "Bash(GVBINDIR=* *:*)",
      "Bash(GVTS_POS_DUMP=* *:*)",
      "Bash(GVTS_POS_INJECT=* *:*)",
      "Bash(GVTS_XL_KEYS=* *:*)",
      "Bash(pgrep *:*)",
      "Bash(pkill *:*)",
      "Bash(nohup *:*)",
      "Bash(rg:*)",
      "Bash(shellcheck:*)",
      "Bash(command -v:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir *:*)",
      "Bash(cp *:*)",
      "Bash(mv *:*)",
      "Bash(rm -f *:*)",
      "Bash(chmod *:*)",
      "Bash(find *:*)",
      "Bash(grep *:*)",
      "Bash(wc *:*)",
      "Bash(sort *:*)",
      "Bash(head *:*)",
      "Bash(tail *:*)",
      "Bash(diff *:*)",
      "Bash(sed *:*)",
      "Bash(awk *:*)",
      "Bash(paste *:*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "mcp__serena__list_dir",
      "mcp__serena__find_file",
      "mcp__serena__find_symbol",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__search_for_pattern",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__insert_before_symbol",
      "mcp__serena__safe_delete_symbol",
      "mcp__serena__rename_symbol"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/session-start.sh", "async": true } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [
        { "type": "command", "command": "~/.claude/hooks/record-turn-start.sh", "async": true },
        { "type": "command", "command": "~/.claude/hooks/project-init.sh", "async": true }
      ] }
    ],
    "PostCompact": [
      { "hooks": [ { "type": "command", "command": "cat ~/.claude/post-compact-context.md" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "echo '-- COMPACTING: re-read plans/sfdp-tracked-divergences/README.md + decision-journal.md from disk; verify open task commits --'" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Write|Edit|MultiEdit", "hooks": [ { "type": "command", "command": "python3 ~/.claude/hooks/check-complexity.py" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/notify-on-stop.sh", "async": true } ] }
    ]
  }
}
